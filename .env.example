# Primary Neo4j AuraDB connection (used by every agent)
# AuraDB uses the instance ID as username and database name (not "neo4j").
NEO4J_URI=neo4j+s://<instance-id>.databases.neo4j.io
NEO4J_USER=<instance-id>
NEO4J_PASSWORD=<auto-generated-password>
NEO4J_DATABASE=<instance-id>

# Eval 2 — clone instance for graph-shuffle perturbation runs.
# Required by src/evaluation/eval2_robustness.py. Spin up a separate AuraDB
# instance and put its credentials here.
CLONE_NEO4J_URI=neo4j+s://<clone-instance-id>.databases.neo4j.io
CLONE_NEO4J_USER=<clone-instance-id>
CLONE_NEO4J_PASSWORD=<clone-auto-generated-password>
CLONE_NEO4J_DATABASE=<clone-instance-id>

# Gemini — Vertex AI Express API key (preferred). Format: AQ.AbXXX...
# If using direct Gemini API instead, set GEMINI_API_KEY (AIza...) and leave GOOGLE_API_KEY blank.
GOOGLE_API_KEY=
GEMINI_API_KEY=
GOOGLE_CLOUD_PROJECT=
GOOGLE_CLOUD_LOCATION=us-central1

# Gemini model tiers
# Lite tier — extraction, mapping, batch tasks
GEMINI_MODEL=gemini-3.1-flash-lite-preview
# Pro tier — Critic Agent, mechanistic reasoning (target_disease)
GEMINI_MODEL_PRO=gemini-3.1-pro-preview

# Anthropic — Eval 5 LLM-as-Judge
ANTHROPIC_API_KEY=

# Groq — Eval 3 Llama benchmark slot
GROQ_API_KEY=

# PubMed E-utilities (optional, raises rate limits)
NCBI_API_KEY=

# Semantic Scholar (optional)
S2_API_KEY=